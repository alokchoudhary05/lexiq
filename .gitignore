# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.pytest_cache/
.coverage
htmlcov/
.ipynb_checkpoints/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Environment secrets (NEVER commit) ───────────────────────────────────────
.env
.env.local
.env.*.local
.env_vercel
.env_render

# ── PDF source files (NOT needed in production) ───────────────────────────────
# All legal data is pre-indexed in Pinecone (cloud).
# PDFs are only needed locally to re-index Pinecone or rebuild BM25 indices.

# ── Runtime / local DB files ──────────────────────────────────────────────────
*.db
*.sqlite3

# ── BM25 indices ARE committed ────────────────────────────────────────────────
# Small files (~5 MB total), load in <1s at startup.
# Enables full hybrid retrieval (Pinecone 60% + BM25 40%) without any PDF loading.
# DO NOT add bm25_indices/ to this gitignore.

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Frontend / Next.js ────────────────────────────────────────────────────────
client/.next/
client/node_modules/
client/.env.local
client/out/
client/dist/

# ── Build / distribution ──────────────────────────────────────────────────────
build/
dist/
*.egg-info/

# ── Deployment / platform ─────────────────────────────────────────────────────
.vercel/
.render/

# ── Misc ──────────────────────────────────────────────────────────────────────
