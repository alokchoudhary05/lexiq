# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Environment secrets (NEVER commit) ───────────────────────────────────────
.env
.env.local
.env.*.local

# ── Legacy / dead code (replaced by fastapi_service/backend/ package) ─────────
lexiq_engine.py

# ── PDF source files (NOT needed in production) ───────────────────────────────
# All legal data is pre-indexed in Pinecone (cloud).
# PDFs are only needed locally to re-index Pinecone or rebuild BM25 pkl cache.
data/*.pdf

# ── BM25 pkl cache IS committed ───────────────────────────────────────────────
# Small files (~5 MB total), load in <1s at startup.
# Enables full hybrid retrieval (Pinecone 60% + BM25 40%) without any PDF loading.
# DO NOT add cache/ to this gitignore.

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Next.js build output ──────────────────────────────────────────────────────
lexiq_web/.next/
lexiq_web/node_modules/
lexiq_web/.env.local

run.txt