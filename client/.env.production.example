# ──────────────────────────────────────────────────────────────
# LexIQ Frontend — Production Environment Variables
# Copy this file, rename to .env.local for local dev,
# or set these in the Vercel dashboard for production.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────

# Supabase (Auth + DB)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service key — server-only, NEVER expose to browser
SUPABASE_SERVICE_KEY=your-service-key-here

# FastAPI backend URL — set to your Railway deployment URL in production
# Example: https://lexiq-api-production.up.railway.app
FASTAPI_URL=http://localhost:8000
